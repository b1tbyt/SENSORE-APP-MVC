@model GrapheneTrace.Models.PatientDashboardViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using System.Text.Json
@{
    ViewData["Title"] = "Patient Dashboard";
    // Build colour scale for heat map
    var colours = new string[32][];
    for (int i = 0; i < 32; i++)
    {
        colours[i] = new string[32];
        for (int j = 0; j < 32; j++)
        {
            byte val = Model.Heatmap[i, j];
            double ratio = (val - 1) / 254.0;
            int red = (int)(255 * ratio);
            int green = (int)(255 * (1 - ratio));
            colours[i][j] = $"rgb({red},{green},0)";
        }
    }
}

<!-- Google Fonts - Montserrat for Sensore Brand -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<!-- Custom styling inspired by LloydsClinical Home -->
<style>
    body {
        background: #f7f7f7;
    }

    .sens-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        margin-bottom: 1rem;
    }

    .sens-card-header {
        background: #0050A0;
        color: #fff;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 12px 12px 0 0;
    }

    .sens-card-body {
        padding: 1rem;
    }

    .btn-primary {
        background: #0050A0;
        border-color: #0050A0;
    }

    .btn-outline-primary {
        color: #0050A0;
        border-color: #0050A0;
    }

    .btn-primary:hover {
        background: #003f80;
    }

    .btn-outline-primary:hover {
        background: #0050A0;
        color: #fff;
    }

    .trend-up {
        color: #28a745;
    }

    .trend-down {
        color: #dc3545;
    }

    .heatmap-table td {
        border: 1px solid #ececec;
        height: 14px;
        padding: 0;
    }

    .messages-container {
        max-height: 180px;
        overflow-y: auto;
        border: 1px solid #e0e0e0;
        padding: 0.5rem;
        border-radius: 8px;
        background: #fff;
    }

    .message-patient {
        color: #0050A0;
        font-weight: 600;
    }

    .message-clinician {
        color: #198754;
        font-weight: 600;
    }

    /* Override font only for the Sensore brand */
    .sensore-brand {
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #0050A0;
    }
</style>

<div class="container-fluid px-4" style="font-size:0.9rem;">
    <h1 class="mb-1 sensore-brand">Sensore</h1>
    <h2 class="mb-4">Patient Dashboard</h2>

    @if (Model.HighPressureAlert)
    {
        <div class="alert alert-danger">
            <strong>High-pressure alert!</strong> One or more pressure readings exceed the safe limit. Please adjust your position or seek assistance.
        </div>
    }

    <div class="row">
        <!-- Heatmap -->
        <div class="col-md-8 mb-3">
            <div class="sens-card">
                <div class="sens-card-header">Live Pressure Map</div>
                <div class="sens-card-body p-1">
                    <div style="overflow-x:auto;">
                        <table class="heatmap-table w-100" style="table-layout:fixed;">
                            <tbody>
                                @for (int i = 0; i < 32; i++)
                                {
                                    <tr>
                                        @for (int j = 0; j < 32; j++)
                                        {
                                            <td title="Value: @Model.Heatmap[i, j]" style="background-color:@colours[i][j];"></td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="mt-2 mb-0"><small>Darker red indicates higher pressure.</small></p>
                </div>
            </div>
        </div>

        <!-- Metrics & Historical -->
        <div class="col-md-4 mb-3">
            <div class="sens-card mb-3">
                <div class="sens-card-header">Historical Data</div>
                <div class="sens-card-body">
                    <form method="get" class="mb-2">
                        <div class="btn-group btn-group-sm">
                            @foreach (var opt in new[] { "1h", "6h", "24h", "7d" })
                            {
                                <button type="submit" name="timeframe" value="@opt" class="btn @(Model.SelectedTimeframe == opt ? "btn-primary" : "btn-outline-primary")">@opt</button>
                            }
                        </div>
                    </form>
                    <div style="height:240px;"><canvas id="pressureChart" style="width:100%; height:100%;"></canvas></div>
                </div>
            </div>
            <div class="sens-card mb-3">
                <div class="sens-card-header">Risk Score</div>
                <div class="sens-card-body">
                    <h4>@Model.RiskScore / 10 (@Model.RiskCategory)</h4>
                    <div class="progress" style="height:10px;">
                        <div class="progress-bar" role="progressbar"
                             style="width:@(Model.RiskScore * 10)%; background-color:@(Model.RiskScore < 3 ? "#28a745" : Model.RiskScore < 7 ? "#ffc107" : "#dc3545");">
                        </div>
                    </div>
                </div>
            </div>
            <div class="sens-card mb-3">
                <div class="sens-card-header">Peak Pressure</div>
                <div class="sens-card-body">
                    <h4>
                        @Model.LatestPeakPressure
                        @Html.Raw(Model.PeakTrend >= 0
                            ? "<span class=\"trend-up\">↑</span>"
                            : "<span class=\"trend-down\">↓</span>")
                    </h4>
                    <p class="mb-0">Highest sensor value (0–255).</p>
                </div>
            </div>
            <div class="sens-card">
                <div class="sens-card-header">Contact Area</div>
                <div class="sens-card-body">
                    <h4>
                        @Model.LatestContactArea %
                        @Html.Raw(Model.ContactTrend >= 0
                            ? "<span class=\"trend-up\">↑</span>"
                            : "<span class=\"trend-down\">↓</span>")
                    </h4>
                    <p class="mb-0">Percent of sensors ≥ @GrapheneTrace.Controllers.PatientController.ContactThreshold.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- New row: Next reposition & Quick actions -->
    <div class="row">
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Next Reposition</div>
                <div class="sens-card-body">
                    <h4>@Model.NextRepositionTime.ToLocalTime().ToString("HH:mm")</h4>
                    <p class="mb-0">in @Math.Ceiling(Model.MinutesUntilReposition) minutes</p>
                    <button type="button" class="btn btn-primary mt-2">Log Reposition</button>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Quick Actions</div>
                <div class="sens-card-body">
                    <a href="#" class="btn btn-outline-primary w-100 mb-2">Contact Support</a>
                    <a href="#" class="btn btn-outline-primary w-100">View FAQs</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Note and Messages -->
    <div class="row">
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Add a Note</div>
                <div class="sens-card-body">
                    @if (TempData["NoteConfirmation"] != null)
                    {
                        <div class="alert alert-success">@TempData["NoteConfirmation"]</div>
                    }
                    <form asp-action="AddNote" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SelectedTimeframe" value="@Model.SelectedTimeframe" />
                        <div class="mb-2">
                            <label class="form-label">Timestamp (optional)</label>
                            <input type="datetime-local" name="NoteTimestamp" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Note</label>
                            <textarea name="NewNote" class="form-control" rows="3" placeholder="Enter your note…"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Submit Note</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Messages</div>
                <div class="sens-card-body">
                    @if (TempData["MessageConfirmation"] != null)
                    {
                        <div class="alert alert-success">@TempData["MessageConfirmation"]</div>
                    }
                    <div class="messages-container mb-2">
                        @foreach (var msg in Model.Messages.OrderBy(m => m.Timestamp))
                        {
                            <div class="mb-2">
                                <span class="@(msg.Sender == "Patient" ? "message-patient" : "message-clinician")">@msg.Sender</span>
                                <small class="text-muted">(@msg.Timestamp.ToLocalTime())</small>
                                <div>@msg.Text</div>
                            </div>
                        }
                    </div>
                    <form asp-action="AddMessage" method="post" class="d-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SelectedTimeframe" value="@Model.SelectedTimeframe" />
                        <input type="text" name="NewMessage" class="form-control me-2" placeholder="Type a message…" />
                        <button type="submit" class="btn btn-primary">Send</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="GenerateReport" class="btn btn-outline-primary">Generate Personal Report</a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.Timestamps));
        const peak = @Html.Raw(JsonSerializer.Serialize(Model.PeakPressureIndices));
        const area = @Html.Raw(JsonSerializer.Serialize(Model.ContactAreaPercentages));

        const ctx = document.getElementById('pressureChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels.map(t => new Date(t).toLocaleString()),
                datasets: [
                    { label: 'Peak Pressure Index', data: peak, borderColor: '#0050A0', fill: false },
                    { label: 'Contact Area (%)', data: area, borderColor: '#28a745', fill: false }
                ]
            },
            options: {
                scales: { y: { beginAtZero: true } },
                maintainAspectRatio: false
            }
        });
    </script>
}