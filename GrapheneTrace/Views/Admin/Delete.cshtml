@model GrapheneTrace.Models.User
@{
    ViewData["Title"] = "Delete User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 mb-0">
                <i class="fas fa-user-minus me-2 text-danger"></i>Delete User
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Delete User</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    <!-- Warning Card -->
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="m-0 fw-bold">
                        <i class="fas fa-exclamation-triangle me-2"></i>Confirm User Deletion
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Warning:</strong> You are about to deactivate this user account.
                        The user will no longer be able to access the system, and any patient-clinician assignments
                        involving this user will be removed.
                    </div>

                    <!-- User Details Card -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="avatar-circle-lg me-3 bg-@(Model.Role == "Admin" ? "danger" : Model.Role == "Clinician" ? "primary" : "success") text-white">
                                    @Model.FirstName[0]@Model.LastName[0]
                                </div>
                                <div>
                                    <h4 class="mb-0">@(Model.Role == "Clinician" ? "Dr. " : "")@Model.FirstName @Model.LastName</h4>
                                    <span class="badge @(Model.Role == "Admin" ? "bg-danger" : Model.Role == "Clinician" ? "bg-primary" : "bg-success")">
                                        @Model.Role
                                    </span>
                                </div>
                            </div>

                            <hr>

                            <div class="row">
                                <div class="col-md-6">
                                    <p class="mb-2">
                                        <i class="fas fa-envelope me-2 text-muted"></i>
                                        <strong>Email:</strong> @Model.Email
                                    </p>
                                    <p class="mb-2">
                                        <i class="fas fa-calendar me-2 text-muted"></i>
                                        <strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                                    </p>
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-2">
                                        <i class="fas fa-id-badge me-2 text-muted"></i>
                                        <strong>User ID:</strong> @Model.UserId
                                    </p>
                                    <p class="mb-2">
                                        <i class="fas fa-toggle-on me-2 text-muted"></i>
                                        <strong>Status:</strong>
                                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                                            @(Model.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Options -->
                    <div class="card border-warning mb-4">
                        <div class="card-header bg-warning text-dark">
                            <strong><i class="fas fa-cog me-2"></i>Deletion Options</strong>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card h-100">
                                        <div class="card-body text-center">
                                            <i class="fas fa-user-slash fa-3x text-warning mb-3"></i>
                                            <h5>Soft Delete (Recommended)</h5>
                                            <p class="text-muted small">
                                                Deactivates the user account. The user data is preserved but they
                                                cannot log in. Can be reactivated later.
                                            </p>
                                            <form asp-action="Delete" method="post">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-warning">
                                                    <i class="fas fa-user-slash me-2"></i>Deactivate User
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card h-100 border-danger">
                                        <div class="card-body text-center">
                                            <i class="fas fa-trash-alt fa-3x text-danger mb-3"></i>
                                            <h5>Permanent Delete</h5>
                                            <p class="text-muted small">
                                                <strong class="text-danger">Irreversible!</strong>
                                                Permanently removes the user from the database.
                                                All associated data will be lost.
                                            </p>
                                            <form asp-action="HardDelete" method="post"
                                                  onsubmit="return confirm('Are you absolutely sure? This action CANNOT be undone!');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@Model.UserId" />
                                                <button type="submit" class="btn btn-danger">
                                                    <i class="fas fa-trash-alt me-2"></i>Permanently Delete
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Cancel Button -->
                    <div class="text-center">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-times me-2"></i>Cancel and Return to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .avatar-circle-lg {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.5rem;
        }
    </style>
}
