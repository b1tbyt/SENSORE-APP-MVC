@{
    ViewData["Title"] = "System Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2 mb-1"><i class="fas fa-cog me-2 text-primary"></i>System Settings</h1>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li><li class="breadcrumb-item active">Settings</li></ol></nav>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-2"></i>Back</a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white"><h6 class="m-0 fw-bold"><i class="fas fa-database me-2"></i>Database Information</h6></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Status</label>
                        <div><span class="badge bg-success fs-6"><i class="fas fa-check-circle me-1"></i>@ViewBag.DatabaseStatus</span></div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Total Users</label>
                        <div class="fs-4 fw-bold">@ViewBag.TotalUsers</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Active Users</label>
                        <div class="fs-4 fw-bold text-success">@ViewBag.ActiveUsers</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label text-muted small">Total Assignments</label>
                        <div class="fs-4 fw-bold text-info">@ViewBag.TotalAssignments</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark"><h6 class="m-0 fw-bold"><i class="fas fa-shield-alt me-2"></i>Security Settings</h6></div>
            <div class="card-body">
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label">Password Hashing (SHA256)</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label">Anti-Forgery Token Validation</label>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label">Role-Based Access Control</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" checked disabled>
                    <label class="form-check-label">Audit Logging</label>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white"><h6 class="m-0 fw-bold"><i class="fas fa-info-circle me-2"></i>System Info</h6></div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between"><span>Version</span><strong>@ViewBag.SystemVersion</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Framework</span><strong>.NET 8.0</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Database</span><strong>In-Memory</strong></li>
                <li class="list-group-item d-flex justify-content-between"><span>Server Time</span><strong>@ViewBag.ServerTime</strong></li>
            </ul>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-info text-white"><h6 class="m-0 fw-bold"><i class="fas fa-tools me-2"></i>Quick Actions</h6></div>
            <div class="card-body">
                <a asp-action="ExportUsers" class="btn btn-outline-primary w-100 mb-2"><i class="fas fa-download me-2"></i>Export Users</a>
                <a asp-action="AuditLogs" class="btn btn-outline-secondary w-100 mb-2"><i class="fas fa-history me-2"></i>View Audit Logs</a>
                <a asp-action="Reports" class="btn btn-outline-success w-100"><i class="fas fa-chart-bar me-2"></i>View Reports</a>
            </div>
        </div>
    </div>
</div>
