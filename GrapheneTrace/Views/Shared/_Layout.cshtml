@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var userName = User.Identity?.Name ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GrapheneTrace Sensore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --dark-bg: #1a1a2e;
        }

        body {
            background-color: #f4f6f9;
        }

        .navbar-custom {
            background: var(--dark-bg);
            padding: 0.75rem 1rem;
        }

            .navbar-custom .navbar-brand {
                color: white;
                font-weight: 700;
                font-size: 1.25rem;
            }

            .navbar-custom .nav-link {
                color: rgba(255,255,255,0.8);
                margin: 0 0.25rem;
                padding: 0.5rem 1rem;
                border-radius: 8px;
                transition: all 0.2s;
            }

                .navbar-custom .nav-link:hover, .navbar-custom .nav-link.active {
                    color: white;
                    background: rgba(255,255,255,0.1);
                }

        .user-badge {
            background: rgba(255,255,255,0.1);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            color: white;
            font-size: 0.875rem;
        }

        footer {
            background: var(--dark-bg);
            color: rgba(255,255,255,0.6);
            padding: 1rem 0;
            margin-top: auto;
        }

        .container-fluid {
            padding: 1.5rem 2rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-heartbeat me-2"></i>Sensore <span class="fw-normal">@userRole Portal</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        @if (userRole == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-tachometer-alt me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Create">
                                    <i class="fas fa-user-plus me-1"></i>Add User
                                </a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center">
                        <span class="user-badge me-3">
                            <i class="fas fa-user me-1"></i>@userName
                        </span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm">
                            Logout
                        </a>
                    </div>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container-fluid flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer>
        <div class="container-fluid d-flex justify-content-between">
            <span>&copy; 2025 - Sensore by GrapheneTrace - <a href="#" class="text-decoration-none">Privacy</a></span>
            <span>Pressure Ulcer Prevention System v1.0</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
