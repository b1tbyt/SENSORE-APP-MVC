@model IEnumerable<SensoreApp.Models.PatientRecord>

<h2>Patient Medical Records</h2>

<a href="/Clinician/AddRecord">Add Medical Record</a>

<br />
<br />

<table border="1" cellpadding="5">
    <tr>
        <th>Patient Name</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>

    @foreach (var record in Model)
    {
        <tr>
            <td>@record.PatientName (#@record.PatientID)</td>

            <td>@record.MedicalStatus</td>
            <td>
                <a href="/Clinician/RecordDetails/@record.Id">View</a> |
                <a href="/Clinician/EditPatientRecord/@record.Id">Edit</a> |
                <a href="/Clinician/DeleteRecord/@record.Id">Delete</a>
            </td>
        </tr>
    }
</table>
