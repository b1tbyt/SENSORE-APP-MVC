@model SENSORE_APP.Models.PatientDashboardViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using System.Text.Json
@{
    ViewData["Title"] = "Patient Dashboard";
    // Build colour scale for heat map
    var colours = new string[32][];
    for (int i = 0; i < 32; i++)
    {
        colours[i] = new string[32];
        for (int j = 0; j < 32; j++)
        {
            byte val = Model.Heatmap[i, j];
            double ratio = (val - 1) / 254.0;
            int red = (int)(255 * ratio);
            int green = (int)(255 * (1 - ratio));
            colours[i][j] = $"rgb({red},{green},0)";
        }
    }
}

<!-- Google Fonts - Montserrat for Sensore Brand -->
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap" rel="stylesheet">

<!-- Custom styling inspired by LloydsClinical Home -->
<style>
    body {
        background: #f7f7f7;
    }

    .sens-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.08);
        margin-bottom: 1rem;
    }

    .sens-card-header {
        background: #0050A0;
        color: #fff;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 12px 12px 0 0;
    }

    .sens-card-body {
        padding: 1rem;
    }

    .btn-primary {
        background: #0050A0;
        border-color: #0050A0;
    }

    .btn-outline-primary {
        color: #0050A0;
        border-color: #0050A0;
    }

    .btn-primary:hover {
        background: #003f80;
    }

    .btn-outline-primary:hover {
        background: #0050A0;
        color: #fff;
    }

    .trend-up {
        color: #28a745;
    }

    .trend-down {
        color: #dc3545;
    }

    .heatmap-table td {
        border: 1px solid #ececec;
        height: 14px;
        padding: 0;
    }

    .messages-container {
        max-height: 180px;
        overflow-y: auto;
        border: 1px solid #e0e0e0;
        padding: 0.5rem;
        border-radius: 8px;
        background: #fff;
    }

    .message-patient {
        color: #0050A0;
        font-weight: 600;
    }

    .message-clinician {
        color: #198754;
        font-weight: 600;
    }

    /* Override font only for the Sensore brand */
    .sensore-brand {
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #0050A0;
    }

    /* Tabs Navigation - FIXED */
    .tabs-nav {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        border-bottom: 2px solid #e0e0e0;
    }

    .tabs-nav a {
        padding: 0.75rem 1.5rem;
        text-decoration: none;
        color: #666;
        border-bottom: 3px solid transparent;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .tabs-nav a:hover {
        color: #0050A0;
    }

    /* Active tab styling */
    .tabs-nav a.active {
        color: #0050A0;
        border-bottom: 3px solid #0050A0;
    }

    /* Dashboard tab (active on Dashboard page) */
    .tabs-nav a[asp-action="Index"] {
        color: #0050A0;
        border-bottom: 3px solid #0050A0;
    }

    /* Messages tab (inactive on Dashboard page) */
    .tabs-nav a[asp-action="Messages"] {
        color: #666;
        border-bottom: 3px solid transparent;
    }
</style>

<div class="container-fluid px-4" style="font-size:0.9rem;">
    <div class="d-flex align-items-center mb-4">
        <h1 class="mb-0 sensore-brand">Sensore</h1>
    </div>

    <!-- Tabs Navigation - FIXED with Bootstrap Icons -->
    <div class="tabs-nav">
        <a asp-action="Index" style="padding: 0.75rem 1.5rem; text-decoration: none; color: #0050A0; border-bottom: 3px solid #0050A0; transition: all 0.3s ease;"><i class="bi bi-bar-chart"></i> Dashboard</a>
        <a asp-action="Messages" style="padding: 0.75rem 1.5rem; text-decoration: none; color: #666; border-bottom: 3px solid transparent; transition: all 0.3s ease;"><i class="bi bi-chat-dots"></i> Messages</a>
        <a asp-action="Profile" style="padding: 0.75rem 1.5rem; text-decoration: none; color: #666; border-bottom: 3px solid transparent; transition: all 0.3s ease;"><i class="bi bi-person-circle"></i> Profile</a>
    </div>

    @if (Model.HighPressureAlert)
    {
        <div class="alert alert-danger">
            <strong>High-pressure alert!</strong> One or more pressure readings exceed the safe limit. Please adjust your position or seek assistance.
        </div>
    }

    <div class="row">
        <!-- Heatmap -->
        <div class="col-md-8 mb-3">
            <div class="sens-card">
                <div class="sens-card-header">Live Pressure Map</div>
                <div class="sens-card-body p-1">
                    <div style="overflow-x:auto;">
                        <table class="heatmap-table w-100" style="table-layout:fixed;">
                            <tbody>
                                @for (int i = 0; i < 32; i++)
                                {
                                    <tr>
                                        @for (int j = 0; j < 32; j++)
                                        {
                                            <td title="Value: @Model.Heatmap[i, j]" style="background-color:@colours[i][j];"></td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="mt-2 mb-0"><small>Darker red indicates higher pressure.</small></p>
                </div>
            </div>
        </div>

        <!-- Metrics & Historical -->
        <div class="col-md-4 mb-3">
            <div class="sens-card mb-3">
                <div class="sens-card-header">Historical Data</div>
                <div class="sens-card-body">
                    <form method="get" class="mb-2">
                        <div class="btn-group btn-group-sm">
                            @foreach (var opt in new[] { "1h", "6h", "24h", "7d" })
                            {
                                <button type="submit" name="timeframe" value="@opt" class="btn @(Model.SelectedTimeframe == opt ? "btn-primary" : "btn-outline-primary")">@opt</button>
                            }
                        </div>
                    </form>
                    <div style="height:240px;"><canvas id="pressureChart" style="width:100%; height:100%;"></canvas></div>
                </div>
            </div>
            <div class="sens-card mb-3">
                <div class="sens-card-header">Risk Score</div>
                <div class="sens-card-body">
                    <h4>@Model.RiskScore / 10 (@Model.RiskCategory)</h4>
                    <div class="progress" style="height:10px;">
                        <div class="progress-bar" role="progressbar"
                             style="width:@(Model.RiskScore * 10)%; background-color:@(Model.RiskScore < 3 ? "#28a745" : Model.RiskScore < 7 ? "#ffc107" : "#dc3545");">
                        </div>
                    </div>
                </div>
            </div>
            <div class="sens-card mb-3">
                <div class="sens-card-header">Peak Pressure</div>
                <div class="sens-card-body">
                    <h4>
                        @Model.LatestPeakPressure
                        @if (Model.PeakTrend >= 0)
                        {
                            <span class="trend-up"><i class="bi bi-arrow-up"></i></span>
                        }
                        else
                        {
                            <span class="trend-down"><i class="bi bi-arrow-down"></i></span>
                        }
                    </h4>
                    <p class="mb-0">Highest sensor value (0–255).</p>
                </div>
            </div>
            <div class="sens-card">
                <div class="sens-card-header">Contact Area</div>
                <div class="sens-card-body">
                    <h4>
                        @Model.LatestContactArea %
                        @if (Model.ContactTrend >= 0)
                        {
                            <span class="trend-up"><i class="bi bi-arrow-up"></i></span>
                        }
                        else
                        {
                            <span class="trend-down"><i class="bi bi-arrow-down"></i></span>
                        }
                    </h4>
                    <p class="mb-0">Percent of sensors ? @SENSORE_APP.Controllers.PatientController.ContactThreshold.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- New row: Next reposition & Quick actions -->
    <div class="row">
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Next Reposition</div>
                <div class="sens-card-body">
                    <h4>@Model.NextRepositionTime.ToLocalTime().ToString("HH:mm")</h4>
                    <p class="mb-0">in @Math.Ceiling(Model.MinutesUntilReposition) minutes</p>
                    <form asp-action="LogReposition" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary mt-2"><i class="bi bi-check-circle"></i> Log Reposition</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Quick Actions</div>
                <div class="sens-card-body">
                    <button type="button" class="btn btn-outline-primary w-100 mb-2" data-bs-toggle="modal" data-bs-target="#contactSupportModal"><i class="bi bi-telephone"></i> Contact Support</button>
                    <button type="button" class="btn btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#faqModal"><i class="bi bi-question-circle"></i> View FAQs</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Support Modal -->
    <div class="modal fade" id="contactSupportModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #0050A0; color: white;">
                    <h5 class="modal-title"><i class="bi bi-telephone"></i> Contact Support</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Need immediate assistance? Use one of these methods:</p>
                    <div class="list-group">
                        <a href="tel:+1-800-SENSORE" class="list-group-item list-group-item-action">
                            <strong><i class="bi bi-telephone-fill"></i> Call Support</strong>
                            <small class="d-block text-muted">+1-800-SENSORE (Available 24/7)</small>
                        </a>
                        <a href="mailto:support@sensore.com" class="list-group-item list-group-item-action">
                            <strong><i class="bi bi-envelope-fill"></i> Email Support</strong>
                            <small class="d-block text-muted">support@sensore.com</small>
                        </a>
                        <a href="#" class="list-group-item list-group-item-action" data-bs-toggle="modal" data-bs-target="#contactFormModal">
                            <strong><i class="bi bi-chat-left-text"></i> Send Message</strong>
                            <small class="d-block text-muted">Use our support form</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Form Modal -->
    <div class="modal fade" id="contactFormModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #0050A0; color: white;">
                    <h5 class="modal-title"><i class="bi bi-chat-left-text"></i> Send Support Message</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="SendSupportMessage" method="post" id="supportFormIndex">
                    <div class="modal-body">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" name="subject" id="subjectIndex" class="form-control" placeholder="What is this about?" />
                            <div id="subjectErrorIndex" style="color: #dc3545; font-size: 0.875rem; margin-top: 0.25rem; display: none;">
                                <i class="bi bi-exclamation-circle"></i> Please input a subject before sending
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea name="message" id="supportMessageIndex" class="form-control" rows="4" placeholder="Please describe your issue..."></textarea>
                            <div id="supportMessageErrorIndex" style="color: #dc3545; font-size: 0.875rem; margin-top: 0.25rem; display: none;">
                                <i class="bi bi-exclamation-circle"></i> Please input a text before sending
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <select name="priority" class="form-select">
                                <option value="Low">Low - General inquiry</option>
                                <option value="Medium" selected>Medium - Needs attention</option>
                                <option value="High">High - Urgent issue</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Send Message</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- FAQs Modal -->
    <div class="modal fade" id="faqModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #0050A0; color: white;">
                    <h5 class="modal-title"><i class="bi bi-question-circle"></i> Frequently Asked Questions</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="accordion" id="faqAccordion">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                    <strong>How often should I reposition?</strong>
                                </button>
                            </h2>
                            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    It's recommended to reposition every 30 minutes to prevent pressure ulcers and maintain circulation. The system will remind you with notifications.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                    <strong>What does the pressure map show?</strong>
                                </button>
                            </h2>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    The pressure map shows real-time pressure distribution across your body. Darker red areas indicate higher pressure points that may need attention.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                    <strong>What is the Risk Score?</strong>
                                </button>
                            </h2>
                            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    The Risk Score (0-10) indicates your current risk of pressure ulcers. Low (0-3): Green, Moderate (3-7): Yellow, High (7-10): Red.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                    <strong>How do I report discomfort?</strong>
                                </button>
                            </h2>
                            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    Use the Messages tab to send messages to your clinician immediately. Include details about where you feel discomfort and severity.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                                    <strong>What should I do during a high-pressure alert?</strong>
                                </button>
                            </h2>
                            <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    When you receive a high-pressure alert, adjust your position immediately. If you cannot reposition yourself, contact support right away.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Note and Messages -->
    <div class="row">
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Add a Note</div>
                <div class="sens-card-body">
                    @if (TempData["NoteConfirmation"] != null)
                    {
                        <div class="alert alert-success">@TempData["NoteConfirmation"]</div>
                    }
                    <form asp-action="AddNote" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SelectedTimeframe" value="@Model.SelectedTimeframe" />
                        <div class="mb-2">
                            <label class="form-label">Timestamp (optional)</label>
                            <input type="datetime-local" name="NoteTimestamp" class="form-control" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Note</label>
                            <textarea name="NewNote" class="form-control" rows="3" placeholder="Enter your note…"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Submit Note</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="sens-card mt-3">
                <div class="sens-card-header">Messages</div>
                <div class="sens-card-body">
                    @if (TempData["MessageConfirmation"] != null)
                    {
                        <div class="alert alert-success">@TempData["MessageConfirmation"]</div>
                    }
                    <div class="messages-container mb-2">
                        @foreach (var msg in Model.Messages.OrderBy(m => m.Timestamp))
                        {
                            <div class="mb-2">
                                <span class="@(msg.Sender == "Patient" ? "message-patient" : "message-clinician")">@msg.Sender</span>
                                <small class="text-muted">(@msg.Timestamp.ToLocalTime())</small>
                                <div>@msg.Text</div>
                            </div>
                        }
                    </div>
                    <form asp-action="AddMessage" method="post" class="d-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="SelectedTimeframe" value="@Model.SelectedTimeframe" />
                        <input type="text" name="NewMessage" class="form-control me-2" placeholder="Type a message…" />
                        <button type="submit" class="btn btn-primary">Send</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <form asp-action="GenerateReport" method="get" style="display:inline;">
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-file-text"></i> Generate Personal Report</button>
        </form>
        <button type="button" class="btn btn-outline-primary ms-2" onclick="downloadReport('pdf')"><i class="bi bi-download"></i> Download as PDF</button>
        <button type="button" class="btn btn-outline-primary ms-2" onclick="downloadReport('csv')"><i class="bi bi-download"></i> Download as CSV</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        /**
         * DASHBOARD PAGE SCRIPTS
         * 
         * This section contains all JavaScript functionality for the Patient Dashboard,
         * including chart rendering, report generation, and form validation.
         */

        // ============================================================
        // CHART.JS - Pressure History Chart
        // ============================================================
        // Serialize model data from the backend for use in the chart
        const labels = @Html.Raw(JsonSerializer.Serialize(Model.Timestamps));
        const peak = @Html.Raw(JsonSerializer.Serialize(Model.PeakPressureIndices));
        const area = @Html.Raw(JsonSerializer.Serialize(Model.ContactAreaPercentages));

        // Get canvas element and create 2D drawing context for Chart.js
        const ctx = document.getElementById('pressureChart').getContext('2d');
        
        // Initialize Chart.js line chart with dual datasets
        new Chart(ctx, {
            type: 'line',
            data: {
                // Convert timestamps to readable format for x-axis labels
                labels: labels.map(t => new Date(t).toLocaleString()),
                datasets: [
                    // Peak Pressure Index dataset (blue color)
                    { label: 'Peak Pressure Index', data: peak, borderColor: '#0050A0', fill: false },
                    // Contact Area dataset (green color)
                    { label: 'Contact Area (%)', data: area, borderColor: '#28a745', fill: false }
                ]
            },
            options: {
                // Start y-axis at zero for accurate visualization
                scales: { y: { beginAtZero: true } },
                // Maintain responsive aspect ratio
                maintainAspectRatio: false
            }
        });

        /**
         * REPORT DOWNLOAD HANDLER
         * 
         * Initiates a download of the patient report in the specified format (PDF or CSV).
         * Called when user clicks download buttons.
         */
        function downloadReport(format) {
            // Navigate to the download endpoint with the specified format parameter
            window.location.href = `/Patient/DownloadReport?format=${format}`;
        }

        /**
         * REPORT VIEW HANDLER
         * 
         * Fetches and displays the patient report as a JSON response.
         * Useful for viewing comprehensive report data in a modal or page.
         */
        function viewReport() {
            // Fetch report data from the server asynchronously
            fetch('/Patient/ViewReport')
                // Parse the response as JSON
                .then(response => response.json())
                // Handle the parsed data
                .then(data => {
                    console.log('Report Data:', data);
                    // Display report summary to user in an alert
                    alert(`Report Generated:\n\nPeak Pressure: ${data.peakPressure}\nRisk Score: ${data.riskScore}\n\nFull report will be displayed.`);
                })
                // Handle any fetch errors
                .catch(error => console.error('Error:', error));
        }

        /**
         * REPOSITION LOGGING WITH VISUAL FEEDBACK
         * 
         * Handles the "Log Reposition" button click event.
         * Provides visual feedback by temporarily changing button text to "Logged!"
         * This gives the user immediate confirmation that their action was registered.
         */
        document.addEventListener('DOMContentLoaded', function() {
            // Find the "Log Reposition" button on the page
            const repositionBtn = document.querySelector('button[type="submit"]');
            
            // Verify the button exists and is the reposition button
            if (repositionBtn && repositionBtn.textContent.includes('Log Reposition')) {
                // Attach click event handler for visual feedback
                repositionBtn.addEventListener('click', function(e) {
                    // Update button text to show completion
                    this.innerHTML = '<i class="bi bi-check-circle"></i> Logged!';
                    
                    // Disable button to prevent multiple submissions
                    this.disabled = true;
                    
                    // After 3 seconds, restore button to original state
                    setTimeout(() => {
                        this.innerHTML = '<i class="bi bi-check-circle"></i> Log Reposition';
                        this.disabled = false;
                    }, 3000);
                });
            }

            /**
             * SUPPORT FORM VALIDATION FOR DASHBOARD MODAL
             * 
             * Validates both the subject and message fields in the contact support form modal
             * that appears on the dashboard. Prevents submission if either field is empty.
             * 
             * Note: This form uses "_Index" suffix in IDs to distinguish it from the
             * separate form on the Messages page.
             */
            const supportFormIndex = document.getElementById('supportFormIndex');
            if (supportFormIndex) {
                // Attach form submit handler
                supportFormIndex.addEventListener('submit', function(e) {
                    // Get and trim subject field value
                    const subject = document.getElementById('subjectIndex').value.trim();
                    
                    // Get and trim message field value
                    const message = document.getElementById('supportMessageIndex').value.trim();
                    
                    // Get references to error message elements
                    const subjectError = document.getElementById('subjectErrorIndex');
                    const messageError = document.getElementById('supportMessageErrorIndex');
                    
                    // Flag to track overall validation status
                    let isValid = true;
                    
                    /**
                     * VALIDATE SUBJECT FIELD
                     * 
                     * If subject is empty, prevent submission and show error.
                     */
                    if (!subject) {
                        e.preventDefault();
                        // Show error message
                        subjectError.style.display = 'block';
                        // Add visual error styling (red border)
                        document.getElementById('subjectIndex').classList.add('is-invalid');
                        isValid = false;
                    } else {
                        // Hide error message if validation passes
                        subjectError.style.display = 'none';
                        // Remove error styling
                        document.getElementById('subjectIndex').classList.remove('is-invalid');
                    }
                    
                    /**
                     * VALIDATE MESSAGE FIELD
                     * 
                     * If message is empty, prevent submission and show error.
                     */
                    if (!message) {
                        e.preventDefault();
                        // Show error message
                        messageError.style.display = 'block';
                        // Add visual error styling (red border)
                        document.getElementById('supportMessageIndex').classList.add('is-invalid');
                        isValid = false;
                    } else {
                        // Hide error message if validation passes
                        messageError.style.display = 'none';
                        // Remove error styling
                        document.getElementById('supportMessageIndex').classList.remove('is-invalid');
                    }
                    
                    /**
                     * FOCUS FIRST INVALID FIELD
                     * 
                     * If validation failed, guide user to the first empty field.
                     */
                    if (!isValid) {
                        e.preventDefault();
                        // Focus on subject field if it's empty
                        if (!subject) {
                            document.getElementById('subjectIndex').focus();
                        } else {
                            // Otherwise focus on message field
                            document.getElementById('supportMessageIndex').focus();
                        }
                    }
                });
                
                /**
                 * SUBJECT FIELD FOCUS HANDLER
                 * 
                 * Clear error message and styling when user interacts with the field.
                 */
                document.getElementById('subjectIndex').addEventListener('focus', function() {
                    // Hide error message
                    document.getElementById('subjectErrorIndex').style.display = 'none';
                    // Remove error styling
                    this.classList.remove('is-invalid');
                });
                
                /**
                 * MESSAGE FIELD FOCUS HANDLER
                 * 
                 * Clear error message and styling when user interacts with the field.
                 */
                document.getElementById('supportMessageIndex').addEventListener('focus', function() {
                    // Hide error message
                    document.getElementById('supportMessageErrorIndex').style.display = 'none';
                    // Remove error styling
                    this.classList.remove('is-invalid');
                });
            }
        });
    </script>
}
