@page
@model SensoreAppLogin.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="text-center" style="width:400px;">
        <img src="~/images/logo.png" alt="Logo" width="60" class="mb-3" />
        <h2 class="fw-bold">Sensore</h2>
        <p class="text-muted">Pressure Ulcer Prevention System</p>

        <form method="post" class="card p-4 shadow-sm border-0">
            <div class="form-group mb-3 text-start">
                <label class="fw-semibold">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="Enter your email" required />
            </div>

            <div class="form-group mb-4 text-start">
                <label class="fw-semibold">Login As</label>
                <select asp-for="Role" class="form-select">
                    <option>Patient</option>
                    <option>Clinician</option>
                    <option>Administrator</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
        </form>

        <div class="card mt-4 p-3 shadow-sm border-0">
            <h5 class="fw-semibold mb-3">Quick Demo Login</h5>
            <button type="submit" name="demo" value="Patient" class="btn btn-outline-secondary w-100 mt-2">John Smith (Patient Account)</button>
            <button type="submit" name="demo" value="Clinician" class="btn btn-outline-secondary w-100 mt-2">Dr. Emily Watson (Clinician Account)</button>
            <button type="submit" name="demo" value="Administrator" class="btn btn-outline-secondary w-100 mt-2">Admin User (Administrator Account)</button>
        </div>

        <footer class="mt-4 text-muted small">© 2025 Sensore • MedTech • Chelmsford</footer>
    </div>
</div>
